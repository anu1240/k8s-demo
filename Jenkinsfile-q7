pipeline {
    agent any
    stages {
        stage('Build Docker Image') {
            steps {
                sh '''
                    docker build -t myapp:latest .
                    minikube image load myapp:latest
                '''
            }
        }
        stage('Deploy to Kubernetes') {
            steps {
                sh 'kubectl apply -f q7-deployment.yaml'
            }
        }
        stage('Verify') {
            steps {
                sh 'kubectl get pods'
                sh 'kubectl get svc'
            }
        }
    }
}