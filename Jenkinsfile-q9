pipeline {
    agent any
    stages {
        stage('Build Image') {
            steps {
                sh 'docker build -t healthapp:latest .'
                sh 'minikube image load healthapp:latest'
            }
        }
        stage('Image Scan - Trivy') {
            steps {
                sh 'trivy image --severity HIGH,CRITICAL myapp:latest'
            }
        }
        stage('Apply RBAC') {
            steps {
                sh 'kubectl apply -f q9-rbac.yaml'
            }
        }
        stage('Deploy') {
            steps {
                sh 'kubectl apply -f q7-deployment.yaml'
            }
        }
        stage('Verify') {
            steps {
                sh 'kubectl get pods'
                sh 'kubectl get serviceaccount'
                sh 'kubectl get role'
            }
        }
    }
    post {
        failure { echo 'Security gate FAILED — deployment blocked!' }
        success { echo 'All security checks passed!' }
    }
}